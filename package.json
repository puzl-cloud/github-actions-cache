{
  "name": "github-actions-cache",
  "version": "5.0.0",
  "type": "module",
  "private": true,
  "description": "Cache dependencies and build outputs",
  "main": "dist/restore/index.js",
  "scripts": {
    "build": "tsc && ncc build -o dist/restore src/restore.ts && ncc build -o dist/save src/save.ts && ncc build -o dist/save-only src/saveOnly.ts && ncc build -o dist/restore-only src/restore.ts",
    "test": "tsc --noEmit && jest --coverage",
    "lint": "eslint **/*.ts --cache",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puzl-cloud/github-actions-cache"
  },
  "keywords": [
    "actions",
    "node",
    "cache"
  ],
  "author": "Puzl",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/glob": "^0.6.1",
    "pretty-bytes": "^5.6.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^28.5.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "nock": "^13.5.4",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3"
  }
}
